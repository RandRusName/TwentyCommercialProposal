{
  "name": "mikoton-commercial-proposals",
  "version": "0.1.38",
  "license": "MIT",
  "engines": {
    "node": "^24.5.0",
    "twenty": ">=2.20.0 <2.21.0",
    "npm": "please-use-yarn",
    "yarn": ">=4.0.2"
  },
  "keywords": [],
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "twenty": "twenty",
    "lint": "oxlint -c .oxlintrc.json .",
    "lint:fix": "oxlint --fix -c .oxlintrc.json .",
    "typecheck": "tsgo --noEmit -p tsconfig.spec.json",
    "test": "yarn test:unit",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:document-service": "python3 -m unittest discover -s document-service/tests -v",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:target-smoke": "vitest run --config vitest.target-smoke.config.ts"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260116.1",
    "oxlint": "^0.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "twenty-client-sdk": "2.20.0",
    "twenty-sdk": "2.20.0",
    "twenty-ui": "1.0.0-alpha.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^4.0.0"
  }
}
